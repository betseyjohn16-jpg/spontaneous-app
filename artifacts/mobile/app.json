{
  "expo": {
    "name": "Spontaneous",
    "slug": "spontaneous",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spontaneous",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Let chance pick your next restaurant or plan your entire day. AI-powered hyper-specific suggestions with reservation times, what to wear, and a full itinerary.",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spontaneous.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Spontaneous to use your location to find nearby restaurants and activities.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Spontaneous to use your location to find nearby restaurants and activities."
      }
    },
    "android": {
      "backgroundColor": "#0F0A1A",
      "package": "com.spontaneous.app",
      "versionCode": 1,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F0A1A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "*.replit.app", "pathPrefix": "/" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Spontaneous to use your location to find nearby restaurants and activities."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8f56f4ba-db37-44b2-aa11-a3140de3a2bb"
      }
    }
  }
}
